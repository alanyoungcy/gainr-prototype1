{
  "compilerOptions": {
    "target": "es2016",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "mongoose": [
        "./node_modules/mongoose/types/index.d.ts"
      ],
      "dotenv": [
        "./node_modules/dotenv/lib/main.d.ts"
      ],
      "@switchboard-xyz/on-demand": [
        "./node_modules/@switchboard-xyz/on-demand/dist/types/esm/index.d.ts"
      ]
    },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}